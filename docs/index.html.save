
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Self-Healing Three.js</title>

<style>
  body { margin: 0; overflow: hidden; background: #0a0a0a; }
  #hud {
    position: absolute;
    top: 10px;
    left: 10px;
    color: #00ff88;
    font-family: monospace;
    font-size: 12px;
    z-index: 10;
    white-space: pre;
  }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>

<body>

<div id="hud">BOOTING...</div>

<script>
(() => {

const hud = document.getElementById("hud");

function log(msg) {
  console.log(msg);
  hud.innerText += "\n" + msg;
}

log("ENGINE START");

// -------------------- SCENE --------------------
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x0a0a0a);

// -------------------- CAMERA --------------------
const camera = new THREE.PerspectiveCamera(
  60,
  window.innerWidth / window.innerHeight,
  0.1,
  1000
);
camera.position.set(5, 5, 10);

// -------------------- RENDERER --------------------
const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
document.body.appendChild(renderer.domElement);

log("Renderer attached: " + !!renderer.domElement.parentNode);

// -------------------- LIGHTING (AUTO FIX GUARANTEE) --------------------
const ambient = new THREE.AmbientLight(0xffffff, 0.8);
scene.add(ambient);

const directional = new THREE.DirectionalLight(0xffffff, 1.2);
directional.position.set(10, 10, 10);
scene.add(directional);

log("Lighting OK");

// -------------------- FALLBACK OBJECT (CRITICAL) --------------------
const geometry = new THREE.BoxGeometry(2, 2, 2);
const material = new THREE.MeshStandardMaterial({
  color: 0xffaa00,
  emissive: 0x222200
});

const cube = new THREE.Mesh(geometry, material);
scene.add(cube);

log("Fallback cube added");

// -------------------- AUTO FIX CAMERA --------------------
function autoFixCamera() {
  camera.position.set(5, 5, 10);
  camera.lookAt(0, 0, 0);
}

autoFixCamera();

// -------------------- RESIZE HANDLER --------------------
window.addEventListener("resize", () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

// -------------------- HEALTH CHECK SYSTEM --------------------
function healthCheck() {
  let issues = [];

  if (!renderer.domElement.parentNode) {
    issues.push("Renderer not attached");
  }

  if (scene.children.length === 0) {
    issues.push("Scene empty");
  }

  if (camera.position.length() === 0) {
    issues.push("Camera invalid");
    autoFixCamera();
  }

  if (issues.length > 0) {
    log("FIXING: " + issues.join(", "));
  }
}

setInterval(healthCheck, 2000);

// -------------------- ANIMATION LOOP --------------------
function animate() {
  requestAnimationFrame(animate);

  cube.rotation.x += 0.01;
  cube.rotation.y += 0.01;

  renderer.render(scene, camera);
}

// -------------------- FINAL SAFETY CHECK --------------------
setTimeout(() => {
  const canvasExists = !!document.querySelector("canvas");
  log("Canvas exists: " + canvasExists);

  if (!canvasExists) {
    log("CRITICAL FAIL → forcing renderer rebuild");
    document.body.appendChild(renderer.domElement);
  }

  log("ENGINE READY");
}, 1000);

animate();

})();
</script>

</body>
</html>
git add .

git commit -m "Bootstrap v1.0"

git push origin main

